{
    "name": "dskripchenko/laravel-admin-health",
    "description": "Health-checks dashboard для dskripchenko/laravel-admin (свои чекеры, без spatie/laravel-health).",
    "type": "library",
    "keywords": [
        "laravel",
        "admin",
        "health-check",
        "monitoring",
        "observability",
        "dskripchenko"
    ],
    "homepage": "https://github.com/dskripchenko/laravel-admin-health",
    "license": "MIT",
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/dskripchenko/laravel-admin-health/issues",
        "source": "https://github.com/dskripchenko/laravel-admin-health"
    },
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminHealth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminHealth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminHealth\\AdminHealthServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
